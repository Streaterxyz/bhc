# ─────────────────────────────────────────────────────────────────────
# BHC — environment variables (template)
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values. .env.local is
# gitignored and never committed. Mirror these into Vercel before
# deploying anything that depends on them.
# ─────────────────────────────────────────────────────────────────────

# ─── Neon Postgres ───────────────────────────────────────────────────
# DATABASE_URL: pooled connection (host contains "-pooler") — used by
#   runtime queries from Next.js routes + server components on Vercel.
# DATABASE_URL_UNPOOLED: direct connection (no -pooler) — used by
#   Drizzle Kit migrations. PgBouncer doesn't support all the session
#   commands a migration runner needs.
# Find both strings in the Neon dashboard → Connection Details.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ─── Auth / sessions (Phase 2A — active) ─────────────────────────────
# SESSION_SECRET: signs the lead session JWT (bhc_lead cookie), the
#   magic-link tokens, AND the admin portal tokens/cookie.
#   Generate with:  openssl rand -base64 32
SESSION_SECRET=

# ─── Admin portal (active) ───────────────────────────────────────────
# ADMIN_EMAILS: comma-separated allowlist of admin emails. Anyone on this
#   list can sign in to /admin via magic link (uses Resend to send it).
#   Removing an email here revokes access on their next request.
ADMIN_EMAILS=brendon@brendonhill.co,dan@brendonhill.co,mansour@brendonhill.co,justin@bedrockgroupsydney.com

# ─── Cloudflare Stream — training video (active) ─────────────────────
# Public vars (inlined at build time, safe to expose — they only
# identify which video to embed; playback is gated by Allowed Origins on
# the video itself + the lead session cookie on /training).
#   NEXT_PUBLIC_STREAM_VIDEO_ID: the video UID from the Stream dashboard
#     (e.g. 5d5bc37ffcf54c9b82e996823bffbb81).
#   NEXT_PUBLIC_STREAM_CUSTOMER_CODE: the "customer-XXXXX" subdomain code
#     from the embed snippet (the part before .cloudflarestream.com).
# Leave blank to keep the styled placeholder. Set + redeploy to go live.
NEXT_PUBLIC_STREAM_VIDEO_ID=
NEXT_PUBLIC_STREAM_CUSTOMER_CODE=

# ─── Stripe — $89 toolkit checkout (active) ──────────────────────────
# STRIPE_SECRET_KEY: from Stripe dashboard → Developers → API keys.
#   Use the TEST key (sk_test_…) while building; swap to live (sk_live_…)
#   at launch. When unset, the buy button shows "checkout opening soon".
# STRIPE_WEBHOOK_SECRET: from the webhook endpoint you create pointing at
#   /api/webhooks/stripe (whsec_…). For local testing use the Stripe CLI:
#     stripe listen --forward-to localhost:3000/api/webhooks/stripe
#   and copy the whsec_ it prints.
# NEXT_PUBLIC_SITE_URL: absolute origin used to build Stripe success/cancel
#   URLs (e.g. https://brendonhill.co). Falls back to the request origin
#   if unset, which is fine locally.
# STRIPE_PRICE_ID: the Price (price_…) on your dashboard product. When set,
#   checkout references it (edit price/copy in Stripe without a deploy). When
#   unset, checkout falls back to an inline $89 AUD price. Mode-specific —
#   a live price needs a live secret key.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: the PUBLIC key (pk_live_… / pk_test_…)
#   from Developers → API keys. Safe to expose; powers the custom /checkout
#   Payment Element client-side. Must match the secret key's mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=
# Invoice-first checkout: /checkout finalises a real Stripe Invoice and pays it
#   with the Payment Element, so Stripe natively emails BOTH a numbered GST
#   tax-invoice PDF and a payment-receipt PDF, and refunds reconcile (a real
#   charge backs the invoice → proper credit notes). To get the PDFs, turn ON
#   "Email finalized invoices" AND the "Successful payments" customer receipt
#   in Stripe → Settings → Customer emails.
# STRIPE_TAX_RATE_ID: (optional) a 10% INCLUSIVE GST tax rate (txr_…) to apply
#   to the invoice line so the PDF shows a GST breakdown. We use an explicit
#   rate, not automatic_tax, because the invoice finalises before the customer
#   enters an address (automatic_tax needs one). When unset, the app
#   finds-or-creates a BHC-tagged inclusive GST rate automatically.
STRIPE_TAX_RATE_ID=

# ─── Cloudflare R2 — digital-product downloads (active) ──────────────
# Powers /downloads (presigned, purchase-gated). When any are unset, the
# downloads page shows a "preparing your files" state instead of 500ing.
#   CLOUDFLARE_ACCOUNT_ID: Cloudflare account id (R2 endpoint host).
#   CLOUDFLARE_R2_ACCESS_KEY_ID / _SECRET_ACCESS_KEY: an R2 API token
#     (R2 → Manage API Tokens → create, Object Read scope is enough).
#   CLOUDFLARE_R2_BUCKET: the bucket name holding the kit files.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=

# ─── Resend (transactional email — active) ───────────────────────────
# RESEND_API_KEY: re_… from Resend. When unset, emails are no-ops (the
#   funnel still works, nothing sends). Domain must be verified in Resend.
# RESEND_FROM / RESEND_REPLY_TO: sender + reply-to (FROM domain must be the
#   verified one). Default to hello@ / brendon@ brendonhill.co.
RESEND_API_KEY=
RESEND_FROM=hello@brendonhill.co
RESEND_REPLY_TO=brendon@brendonhill.co
# RESEND_WEBHOOK_SECRET: whsec_… from the Resend webhook endpoint pointing
#   at /api/webhooks/resend (events: email.bounced, email.complained). Flags
#   bounced/complained addresses in the leads table. When unset, the webhook
#   processes without signature verification (set it in prod).
RESEND_WEBHOOK_SECRET=

# ─── Cron (monthly re-engagement nudge — active) ─────────────────────
# CRON_SECRET: any long random string. Vercel Cron attaches it as a Bearer
#   token on scheduled hits to /api/cron/monthly-nudge; the route 401s
#   without it. Generate with: openssl rand -base64 32. Add to Vercel env.
CRON_SECRET=

# ─── Loops (marketing nurture — active) ──────────────────────────────
# LOOPS_API_KEY: from Loops → Settings → API. When unset, all Loops calls
#   are no-ops (the funnel still works, nothing syncs). Resend handles
#   transactional mail; Loops owns marketing sequences, branched off the
#   lifecycle events we fire: signed_up, completed_training, purchased.
LOOPS_API_KEY=

# ─── Anthropic (Claude) — AI menu extraction (active) ────────────────
# ANTHROPIC_API_KEY: sk-ant-… from console.anthropic.com → API keys.
#   Powers the "Scan menu" import on the Menu Margin tool (Claude Haiku
#   4.5 reads a photo/PDF → item names + prices). Server-only / sensitive.
#   When unset, the import button shows a "not available" state; the
#   calculator still works with manual entry.
ANTHROPIC_API_KEY=

# ─── Pexels (stock photos for the Par-Level Calculator — active) ──────
# PEXELS_API_KEY: from pexels.com/api → your API key. Used server-side to
#   fetch a product photo per line item (cached). When unset, the tool
#   falls back to on-brand category placeholders — it still works fully.
PEXELS_API_KEY=

# ─── Phase 2B placeholders (not yet wired) ───────────────────────────
#   CLOUDFLARE_STREAM_TOKEN=          # only if we move to signed URLs

# ─── PostHog (product analytics — active) ────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY: Project API key (phc_…) from PostHog → Settings
#   → Project → API keys. When unset, PostHog is not initialised at all.
# NEXT_PUBLIC_POSTHOG_HOST: region host — https://us.i.posthog.com (US) or
#   https://eu.i.posthog.com (EU). Defaults to US if unset.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ─── Cloudflare Turnstile (bot protection on lead capture) ───────────
# NEXT_PUBLIC_TURNSTILE_SITE_KEY: public site key — renders the widget. When
#   unset, the form renders with no challenge (local dev unblocked).
# TURNSTILE_SECRET_KEY: secret key — server-side token verification in
#   /api/leads. When unset, verification is skipped.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Google Analytics 4 (active) ─────────────────────────────────────
# Measurement ID (G-XXXXXXXXXX) from GA4 → Admin → Data Streams. Injected
# via @next/third-parties only when set; unset = no GA on the page.
NEXT_PUBLIC_GA_ID=
