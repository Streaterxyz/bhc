# ─────────────────────────────────────────────────────────────────────
# BHC — environment variables (template)
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values. .env.local is
# gitignored and never committed. Mirror these into Vercel before
# deploying anything that depends on them.
# ─────────────────────────────────────────────────────────────────────

# ─── Neon Postgres ───────────────────────────────────────────────────
# DATABASE_URL: pooled connection (host contains "-pooler") — used by
#   runtime queries from Next.js routes + server components on Vercel.
# DATABASE_URL_UNPOOLED: direct connection (no -pooler) — used by
#   Drizzle Kit migrations. PgBouncer doesn't support all the session
#   commands a migration runner needs.
# Find both strings in the Neon dashboard → Connection Details.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ─── Auth / sessions (Phase 2A — active) ─────────────────────────────
# SESSION_SECRET: signs the lead session JWT (bhc_lead cookie).
#   Generate with:  openssl rand -base64 32
SESSION_SECRET=

# ─── Cloudflare Stream — training video (active) ─────────────────────
# Public vars (inlined at build time, safe to expose — they only
# identify which video to embed; playback is gated by Allowed Origins on
# the video itself + the lead session cookie on /training).
#   NEXT_PUBLIC_STREAM_VIDEO_ID: the video UID from the Stream dashboard
#     (e.g. 5d5bc37ffcf54c9b82e996823bffbb81).
#   NEXT_PUBLIC_STREAM_CUSTOMER_CODE: the "customer-XXXXX" subdomain code
#     from the embed snippet (the part before .cloudflarestream.com).
# Leave blank to keep the styled placeholder. Set + redeploy to go live.
NEXT_PUBLIC_STREAM_VIDEO_ID=
NEXT_PUBLIC_STREAM_CUSTOMER_CODE=

# ─── Phase 2B placeholders (not yet wired) ───────────────────────────
#   STRIPE_SECRET_KEY=
#   STRIPE_WEBHOOK_SECRET=
#   RESEND_API_KEY=
#   LOOPS_API_KEY=
#   CLOUDFLARE_ACCOUNT_ID=
#   CLOUDFLARE_STREAM_TOKEN=          # only if we move to signed URLs
#   CLOUDFLARE_R2_ACCESS_KEY_ID=
#   CLOUDFLARE_R2_SECRET_ACCESS_KEY=
#   CLOUDFLARE_R2_BUCKET=
#   NEXT_PUBLIC_GA_ID=
#   NEXT_PUBLIC_POSTHOG_KEY=
#   NEXT_PUBLIC_POSTHOG_HOST=
